{
  "name": "hak-pyth-plugin",
  "version": "0.2.1",
  "description": "Hedera Agent Kit plugin for Pyth price feeds",
  "type": "module",
  "license": "MIT",
  "author": "Juanma Gomez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmgomezl/hak-pyth-plugin.git"
  },
  "homepage": "https://github.com/jmgomezl/hak-pyth-plugin#readme",
  "bugs": {
    "url": "https://github.com/jmgomezl/hak-pyth-plugin/issues"
  },
  "keywords": [
    "hedera",
    "pyth",
    "oracle",
    "agent-kit",
    "plugin",
    "price-feeds"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node scripts/integration-test.mjs",
    "example": "node scripts/example.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@hashgraph/hedera-agent-kit": "^4.0.0",
    "@hiero-ledger/sdk": "^2.84.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@hashgraph/hedera-agent-kit": "^4.0.0",
    "@hiero-ledger/sdk": "^2.84.0",
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.11.0",
    "axios-mock-adapter": "^1.22.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
